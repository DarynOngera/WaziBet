<Layouts.admin
  flash={@flash}
  current_scope={@current_scope}
  user_permissions={@user_permissions}
  is_superuser={@is_superuser}
  current_path={@current_path}
>
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div class="flex items-center gap-4">
      <.link navigate={~p"/admin"} class="btn btn-ghost btn-sm">
        <.icon name="hero-arrow-left" class="icon-sm" />
      </.link>
      <div>
        <h1 class="type-h1 text-base-content flex items-center gap-3">
          <.icon name="hero-trophy" class="icon-lg text-primary" /> Game Management
        </h1>
        <p class="type-body text-base-content/60 mt-2">Configure and manage games</p>
      </div>
    </div>

    <.link navigate={~p"/admin/games/new"} class="btn btn-sm btn-primary border">
      <.icon name="hero-plus" class="icon-sm mr-2" /> New Game
    </.link>
  </div>

  <%= if Enum.empty?(@games) do %>
    <div class="card bg-base-100 shadow-xs border border-base-300">
      <div class="card-body text-center py-12">
        <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-base-200 flex items-center justify-center">
          <.icon name="hero-trophy" class="icon-xl text-base-content/30" />
        </div>
        <h2 class="type-h2 font-semibold mb-2">No games found</h2>
        <p class="text-base-content/60 mb-6">Create your first game to start</p>
        <.link navigate={~p"/admin/games/new"} class="btn btn-sm btn-primary border">
          Create Game
        </.link>
      </div>
    </div>
  <% else %>
    <div class="card bg-base-100 shadow-xs border border-base-300 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="table table-zebra table-sm">
          <thead>
            <tr class="bg-base-200 type-caption text-base-content/65">
              <th>Game</th>
              <th>Category</th>
              <th>Status</th>
              <th>Score</th>
              <th>Time</th>
              <th>Viewers</th>
              <th>Outcomes</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <%= for game <- @games do %>
              <tr class="hover type-body-sm">
                <td>
                  <div>
                    <div class="type-body-sm font-medium">
                      {game.home_team.name} vs {game.away_team.name}
                    </div>
                    <div class="type-body-sm text-base-content/60 type-mono">ID: {game.id}</div>
                  </div>
                </td>
                <td>
                  <span class="badge rounded-full badge-outline badge-xs">
                    {game.category.name}
                  </span>
                </td>
                <td>
                  <span class={["badge rounded-full badge-xs", status_color(game.status)]}>
                    {String.capitalize(to_string(game.status))}
                    <%= if game.status == :live do %>
                      ({game.minute}')
                    <% end %>
                  </span>
                </td>
                <td class="type-mono font-bold">
                  <%= if game.status == :scheduled do %>
                    vs
                  <% else %>
                    {game.home_score} - {game.away_score}
                  <% end %>
                </td>
                <td class="type-body-sm">
                  <%= if game.status == :scheduled do %>
                    {format_starts_at(game.starts_at)}
                  <% else %>
                    -
                  <% end %>
                </td>
                <td>
                  <%= if game.status == :live do %>
                    <div class="flex items-center gap-1">
                      <.icon name="hero-eye" class="icon-sm text-base-content/60" />
                      <span class={[
                        "type-mono",
                        Map.get(@viewer_counts, game.id, 0) > 0 && "text-warning font-bold",
                        Map.get(@viewer_counts, game.id, 0) == 0 && "text-base-content/40"
                      ]}>
                        {Map.get(@viewer_counts, game.id, 0)}
                      </span>
                    </div>
                  <% else %>
                    <span class="text-base-content/30">-</span>
                  <% end %>
                </td>
                <td>
                  <%= if game.outcomes != [] do %>
                    <div class="flex gap-1">
                      <%= for outcome <- game.outcomes do %>
                        <span class={[
                          "badge rounded-full badge-xs",
                          outcome.status == :open && "badge-success",
                          outcome.status != :open && "badge-ghost"
                        ]}>
                          {String.first(to_string(outcome.label))}
                        </span>
                      <% end %>
                    </div>
                  <% else %>
                    <span class="type-body-sm text-base-content/50">None</span>
                  <% end %>
                </td>
                <td>
                  <div class="flex gap-2">
                    <.link
                      navigate={~p"/admin/games/#{game.id}"}
                      class="btn btn-ghost btn-xs"
                    >
                      <.icon name="hero-eye" class="icon-sm" />
                    </.link>
                    <%= if game.status == :scheduled do %>
                      <span class="badge badge-info badge-xs">Scheduled</span>
                    <% end %>
                    <%= if game.status == :live do %>
                      <span class="badge badge-success badge-xs">Live {game.minute}'</span>
                    <% end %>
                    <%= if game.status == :finished do %>
                      <span class="text-xs text-base-content/50">Finished</span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <%= if @total_pages > 1 do %>
        <div class="flex flex-col sm:flex-row justify-between items-center gap-3 p-3 border-t border-base-200 bg-base-200/30">
          <div class="type-body-sm text-base-content/60">
            Showing {(@current_page - 1) * page_size() + 1} to {min(
              @current_page * page_size(),
              @total_count
            )} of {@total_count} games
          </div>
          <div class="join">
            <.link
              patch={"/admin/games?page=#{@current_page - 1}"}
              class={"join-item btn btn-xs #{if @current_page <= 1, do: "btn-disabled pointer-events-none"}"}
            >
              <.icon name="hero-chevron-left" class="icon-sm" />
            </.link>
            <span class="join-item btn btn-xs btn-ghost">
              Page {@current_page} of {@total_pages}
            </span>
            <.link
              patch={"/admin/games?page=#{@current_page + 1}"}
              class={"join-item btn btn-xs #{if @current_page >= @total_pages, do: "btn-disabled pointer-events-none"}"}
            >
              <.icon name="hero-chevron-right" class="icon-sm" />
            </.link>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</Layouts.admin>
