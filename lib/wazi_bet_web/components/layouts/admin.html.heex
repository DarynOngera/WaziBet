<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="WaziBet" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <header class="navbar bg-base-200 border-b border-base-300 sticky top-0 z-50 h-16">
      <div class="navbar-start">
        <button
          id="admin-mobile-menu-btn"
          class="lg:hidden btn btn-ghost btn-square"
          phx-click={JS.toggle(to: "#admin-sidebar")}
        >
          <.icon name="hero-bars-3" class="w-6 h-6" />
        </button>
        <.link
          href={~p"/admin/dashboard"}
          class="btn btn-ghost text-xl font-bold tracking-wider ml-2"
        >
          <span class="text-primary">WAZI</span><span class="text-secondary">BET</span>
          <span class="text-base-content/50 ml-1 text-sm font-normal">Admin</span>
        </.link>
      </div>
      <div class="navbar-end">
        <.link href={~p"/"} class="btn btn-sm btn-ghost">
          <.icon name="hero-arrow-left-start-on-rectangle" class="w-4 h-4 mr-1" /> Back to Site
        </.link>
        <.link href={~p"/users/log-out"} method="delete" class="btn btn-sm btn-ghost text-error">
          <.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4" />
        </.link>
      </div>
    </header>

    <div class="flex min-h-[calc(100vh-4rem)]">
      <%!-- Sidebar Overlay (mobile) --%>
      <div
        id="sidebar-overlay"
        class="fixed inset-0 bg-black/50 z-30 lg:hidden hidden"
        phx-click={JS.toggle(to: "#admin-sidebar")}
      >
      </div>

      <%!-- Sidebar --%>
      <aside
        id="admin-sidebar"
        class="fixed lg:sticky top-16 inset-y-16 left-0 z-40 w-72 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 bg-base-200 border-r border-base-300 flex flex-col"
      >
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <.link
            navigate={~p"/admin/dashboard"}
            class={[
              "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all",
              @current_path == "/admin/dashboard" && "bg-primary text-primary-content font-medium",
              @current_path != "/admin/dashboard" && "hover:bg-base-300 text-base-content"
            ]}
          >
            <.icon name="hero-home" class="w-5 h-5" />
            <span>Dashboard</span>
          </.link>

          <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mt-4 mb-2 px-3">
            Management
          </div>

          <%= if has_permission?(@user_permissions, "view-users") do %>
            <.link
              navigate={~p"/admin/users"}
              class={[
                "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all",
                String.starts_with?(@current_path, "/admin/users") &&
                  "bg-primary text-primary-content font-medium",
                !String.starts_with?(@current_path, "/admin/users") &&
                  "hover:bg-base-300 text-base-content"
              ]}
            >
              <.icon name="hero-users" class="w-5 h-5" />
              <span>Users</span>
            </.link>
          <% end %>

          <%= if has_permission?(@user_permissions, "configure-games") do %>
            <div class="relative">
              <button
                phx-click={JS.toggle(to: "#games-menu", in: "hidden", out: "hidden")}
                class={[
                  "flex items-center justify-between w-full gap-3 px-3 py-2.5 rounded-lg transition-all",
                  (String.starts_with?(@current_path, "/admin/games") or
                     String.starts_with?(@current_path, "/admin/categories") or
                     String.starts_with?(@current_path, "/admin/teams")) &&
                    "bg-primary text-primary-content font-medium",
                  !(String.starts_with?(@current_path, "/admin/games") or
                      String.starts_with?(@current_path, "/admin/categories") or
                      String.starts_with?(@current_path, "/admin/teams")) &&
                    "hover:bg-base-300 text-base-content"
                ]}
              >
                <div class="flex items-center gap-3">
                  <.icon name="hero-trophy" class="w-5 h-5" />
                  <span>Games</span>
                </div>
                <.icon name="hero-chevron-down" class="w-4 h-4" />
              </button>
              <div id="games-menu" class="hidden pl-8 mt-1 space-y-1">
                <.link
                  navigate={~p"/admin/categories"}
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm hover:bg-base-300 transition-all"
                >
                  <.icon name="hero-sport-court" class="w-4 h-4" />
                  <span>Categories</span>
                </.link>
                <.link
                  navigate={~p"/admin/teams"}
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm hover:bg-base-300 transition-all"
                >
                  <.icon name="hero-user-group" class="w-4 h-4" />
                  <span>Teams</span>
                </.link>
                <.link
                  navigate={~p"/admin/games"}
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm hover:bg-base-300 transition-all"
                >
                  <.icon name="hero-list-bullet" class="w-4 h-4" />
                  <span>All Games</span>
                </.link>
                <.link
                  navigate={~p"/admin/games/new"}
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm hover:bg-base-300 transition-all"
                >
                  <.icon name="hero-plus-circle" class="w-4 h-4" />
                  <span>New Game</span>
                </.link>
              </div>
            </div>
          <% end %>

          <%= if has_permission?(@user_permissions, "assign-roles") do %>
            <.link
              navigate={~p"/admin/roles"}
              class={[
                "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all",
                String.starts_with?(@current_path, "/admin/roles") &&
                  "bg-primary text-primary-content font-medium",
                !String.starts_with?(@current_path, "/admin/roles") &&
                  "hover:bg-base-300 text-base-content"
              ]}
            >
              <.icon name="hero-key" class="w-5 h-5" />
              <span>Roles</span>
            </.link>
          <% end %>

          <%= if has_permission?(@user_permissions, "view-profits-from-losses") do %>
            <.link
              navigate={~p"/admin/profits"}
              class={[
                "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all",
                @current_path == "/admin/profits" && "bg-primary text-primary-content font-medium",
                @current_path != "/admin/profits" && "hover:bg-base-300 text-base-content"
              ]}
            >
              <.icon name="hero-chart-pie" class="w-5 h-5" />
              <span>Profits</span>
            </.link>
          <% end %>

          <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mt-4 mb-2 px-3">
            Account
          </div>

          <.link
            navigate={~p"/users/settings"}
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-base-300 text-base-content transition-all"
          >
            <.icon name="hero-cog-6-tooth" class="w-5 h-5" />
            <span>Settings</span>
          </.link>
        </nav>

        <div class="p-4 border-t border-base-300">
          <div class="flex items-center gap-3">
            <div class="avatar placeholder">
              <div class="bg-primary text-primary-content rounded-full w-10">
                <span class="text-sm">
                  {String.first(@current_scope.user.first_name || "U")}{String.first(
                    @current_scope.user.last_name || ""
                  )}
                </span>
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate">
                {@current_scope.user.first_name} {@current_scope.user.last_name}
              </p>
              <p class="text-xs text-base-content/60 truncate">{@current_scope.user.email}</p>
            </div>
            <%= if @is_superuser do %>
              <div class="badge badge-error badge-sm">Admin</div>
            <% end %>
          </div>
        </div>
      </aside>

      <main class="flex-1 min-h-[calc(100vh-4rem)] bg-base-100 p-4 lg:p-8">
        {render_slot(@inner_block)}
      </main>
    </div>

    <.flash_group flash={@flash} />
  </body>
</html>
